# Server Configuration
NODE_ENV=development
PORT=5000
API_VERSION=v1

# Azure SQL Database Configuration
DB_SERVER=your-sql-server.database.windows.net
DB_PORT=1433
DB_NAME=entra_compliance
DB_USER=your-sql-admin
DB_PASSWORD=your-secure-password
DB_ENCRYPT=true

# Redis Configuration
REDIS_HOST=your-redis-cache.redis.cache.windows.net
REDIS_PORT=6380
REDIS_PASSWORD=your-redis-access-key
REDIS_TLS=true

# Azure AD Configuration
AZURE_CLIENT_ID=your-azure-ad-client-id
AZURE_CLIENT_SECRET=your-azure-ad-client-secret
AZURE_TENANT_ID=your-azure-ad-tenant-id

# JWT Configuration
JWT_SECRET=your-super-secure-jwt-secret-at-least-64-characters-long
JWT_EXPIRES_IN=24h
JWT_REFRESH_EXPIRES_IN=7d

# Email Configuration (Optional - for notifications)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your-email@company.com
SMTP_PASS=your-email-password
FROM_EMAIL=noreply@company.com
FROM_NAME=Entra Management App

# Microsoft Teams Webhook (Optional)
TEAMS_WEBHOOK_URL=https://company.webhook.office.com/webhookb2/...

# Application Insights
APPINSIGHTS_INSTRUMENTATIONKEY=your-application-insights-key

# File Upload Configuration
UPLOAD_MAX_SIZE=10485760
UPLOAD_ALLOWED_TYPES=pdf,doc,docx,txt,json,yaml,yml

# Security Configuration
CORS_ORIGIN=http://localhost:3000
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100
BCRYPT_SALT_ROUNDS=12

# Report Configuration
REPORT_STORAGE_PATH=./uploads/reports
REPORT_RETENTION_DAYS=30

# Scheduled Job Configuration
ENABLE_SCHEDULED_JOBS=true
COMPLIANCE_CHECK_CRON=0 2 * * *
WEEKLY_REPORT_CRON=0 9 * * 1
CACHE_CLEANUP_CRON=0 3 * * *

# Logging Configuration
LOG_LEVEL=info
LOG_FILE=./logs/app.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=5